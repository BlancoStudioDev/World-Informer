<script>
	
	var loggedInVar = 'no';
	var userId = null;
	if (isLogged()) {
		loggedInVar = 'yes';
		var cookieData = JSON.parse(atob(getCookie('__utp').split('.')[1]));
		userId = cookieData['sub'];
	}
	var subscribedVar = 'yes';
	var isAbbonatoCookie = getCookie("sub");
	if (isAbbonatoCookie === undefined || isAbbonatoCookie === '0') {
		subscribedVar = 'no';
	}
	
	var customerTypeVar = 'recurring';
	if (getCookie("euconsent-v2") === undefined) {
		customerTypeVar = 'new';
	}
	
	window.dataLayer = window.dataLayer || [];
	//console.log("DATA LAYER BEFORE ", window.dataLayer);
	
	// Gestione ultima ora da HP
	/*if (getUrlParameter("uohp")) {
		window.dataLayer.push({
			event: "ultimaOra",
			articleURL: window.location.pathname,
			articleTitle: $('.post-single-title').html().trim()
		});
	}
	else {
		window.dataLayer.push({
			event: "globalVariables",
			environment: "staging",
			customerType: customerTypeVar,
			loggedIn: loggedInVar,
			userId: userId,
			subscribed: subscribedVar,
			pageType: "homepage"
		});
	}*/
	//console.log("LOCATION: ", $(location));
	var env = "staging";
	if (($(location).attr("origin").indexOf("ansacmsnew") != -1) || ($(location).attr("origin").indexOf("www.ansa.it") != -1)) {
		env = "prod";
	}
	
	
	
	// SEZIONI
	
  	// HOMEPAGE
  	var pType = "homepage";
	  
	
	var currentSection = getCurrentSection();
	var sectionLabel = currentSection.sectionLabel.toLowerCase();
	
	/*window.dataLayer.push({
			event: "globalVariables",
			environment: env,
			customerType: customerTypeVar,
			loggedIn: loggedInVar,
			userId: userId,
			subscribed: subscribedVar,
			pageType: pType,
			pageSubcategoryLevel2: sectionLabel
		});*/
	
	
	let dataLayerGlobal = Object.assign({},
		{event: "globalVariables"},
		{environment: env},
		{customerType: customerTypeVar},
		{loggedIn: loggedInVar},
	  	userId === null ? null : {userId: userId},
	  	{subscribed: subscribedVar},
		{pageType: pType},
		{pageSubcategoryLevel2: sectionLabel}
	);
		
	window.dataLayer.push(dataLayerGlobal);
		
	console.log("DATA LAYER GLOBAL VARIABLES ", window.dataLayer);
</script>

