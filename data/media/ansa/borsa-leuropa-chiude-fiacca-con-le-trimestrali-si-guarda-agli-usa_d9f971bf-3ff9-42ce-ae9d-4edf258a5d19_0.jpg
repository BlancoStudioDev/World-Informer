  var assetid = MD5(encodeURIComponent(document.location.href));
  var nielsenMetadata = {
    type: 'static', 
    assetid: assetid, // *DYNAMIC METADATA*: unique ID for each article **REQUIRED**


    section: 'AnsaHomepage_BRW' // *DYNAMIC METADATA*: section of site **REQUIRED**	  
	

    }; 
    
