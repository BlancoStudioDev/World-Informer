<script type="text/javascript">
	$(function() {
		const searchRegExp = /ansa-c/g;
		
		var acClassName = "ansa-c";
		
        if (!isMobile()) {
            acClassName = generateString(30);
            //console.log("CLASS NAME: |" + acClassName + "|");


            $.get( "/sito/cssnew/ansa_c.css?281120251130", function( data ) {

                    data = data.replace(searchRegExp, acClassName);

                    //console.log("STYLESHEET: " + data);

                    $('head').append('<style type="text/css">' + data + '</style>');

                    $('.ansa-c').each(function() {
                        $(this).removeClass("ansa-c").addClass(acClassName);
                    });
                });
        }
        
        
		/*document.addEventListener("readystatechange", (event) => {
		  console.log("STATE: ", document.readyState);
		});*/
		
		/*document.addEventListener("visibilitychange", () => {
		  console.log("VISIBILITY: ", !document.hidden);
		  
		  if (!document.hidden) {
		  	setTimeout(function(){
			    console.log("Hello World");
			}, 2000);
		  }
		});*/
	    
	    // CORE WEB VITALS
	    /*var script = document.createElement('script');
	    script.src ='https://unpkg.com/web-vitals@3/dist/web-vitals.attribution.iife.js';
	    script.onload = function () {
	      // When loading `web-vitals` using a classic script, all the public
	      // methods can be found on the `webVitals` global namespace.
	      console.log("TEST222");
	      webVitals.onCLS(console.log);
	      webVitals.onFID(console.log);
	      webVitals.onLCP(console.log);
	    };
	    document.head.appendChild(script);*/

		// ANSACOM
        $(document).on("click", "." + acClassName, function (event) {
		  var ansacomClass = $(this).attr("class") || "";
		
		  var anchor = $(this).find("a");
		  var aClass = anchor.attr("class");
		
		  console.log("aClass: ", aClass);
		
		  // Registro solo in caso non sia un'alta visibilità
		  if (aClass === undefined || aClass.indexOf("m-av") === -1) {
		    event.preventDefault();
		
		    var href = (anchor.attr("href") || "").replace("https://www.ansa.it", "");
		    var title = anchor.text().trim();
		    if (title === "") {
		      title = $(this).attr("title") || "";
		    }
		
		    var aEvent = "articoliAnsaCom";
		    // Controllo se è un alta visibilità
		    if (ansacomClass.indexOf("special") !== -1) {
		      aEvent = "inEvidenzaSponsorizzato";
		    }
		
		    // Costruisco payload base
		    var dlPayload = {
		      event: aEvent,
		      articleURL: href,
		      articleTitle: title
		    };
		
		    // Aggiungo AnsaComType SOLO per articoliAnsaCom
		    if (aEvent === "articoliAnsaCom") {
		      var isInSlider = $(this).closest(".teaser-rotation").length > 0;
		      dlPayload.AnsaComType = isInSlider ? "slider" : "fixed";
		    }
		
		    window.dataLayer = window.dataLayer || [];
		    window.dataLayer.push(dlPayload);
		
		    console.log("DATA LAYER " + aEvent.toUpperCase(), window.dataLayer);
		    setTimeout(function () {
		      location.href = href;
		     }, 1000);
		  }
		});
        
        // SPECIALI IN EVIDENZA
        $(document).on('click', 'a[data-track]', function (e) {
		  	e.preventDefault();
		  
			const url = $(this).attr('href');
		  	const text = $(this).text().trim();
			const evento = $(this).data('track'); 
			  
			window.dataLayer = window.dataLayer || [];
		    window.dataLayer.push({
				event: evento,
				articleURL: url,
				articleTitle: text
			});
			
			console.log("DATA LAYER " + evento.toUpperCase(), window.dataLayer);
		    //setTimeout(function(){location.href = url}, 1000);
		});
        
		// ALTA VISIBILITA GA4
		$('.m-av').click(function(event){
			event.preventDefault();
			var href = $(this).attr('href').replace('https://www.ansa.it', '');
			var title = $(this).text().trim();
			
			if (title === '') {
				title = $(this).attr('title');
			}
			
		    window.dataLayer = window.dataLayer || [];
		    window.dataLayer.push({
				event: "altaVisibilita",
				articleURL: href,
				articleTitle: title
			});
			console.log("DATA LAYER ALTA VISIBILITA ", window.dataLayer);
		    setTimeout(function(){location.href = href}, 1000);
		});
		
		// IN EVIDENZA GA4
		$('.in-evidenza').click(function(event){
			event.preventDefault();
			var href = $(this).attr('href').replace('https://www.ansa.it', '');
			var title = $(this).text().trim();
			
			if (title === '') {
				//console.log("TITLE NOT FOUND!");
				title = $(this).attr('title');
			}
			//console.log("TITLE: ", title);
			
			var newsType = 'articolo';
			
			if (href !== '') {
				if (href.indexOf("photogallery") !== -1) {
					newsType = 'foto';
				}
				if (href.indexOf("videogallery") !== -1) {
					newsType = 'video';
				}
			}
			
		    window.dataLayer = window.dataLayer || [];
		    window.dataLayer.push({
				event: "inEvidenza",
				articleURL: href,
				articleTitle: title,
				articleType: newsType
			});
			console.log("DATA LAYER IN EVIDENZA ", window.dataLayer);
		    setTimeout(function(){location.href = href}, 1000);
		});
		
		// ULTIMA ORA GA4
		$('.uora').click(function(event){
			event.preventDefault();
			var href = $(this).attr('href');
			
		    window.dataLayer = window.dataLayer || [];
		    window.dataLayer.push({
				event: "ultimaOra",
				articleURL: href,
				articleTitle: $(this).text().trim()
			});
			console.log("DATA LAYER ULTIMA ORA ", window.dataLayer);
		    setTimeout(function(){location.href = href}, 1000);
		});
		
		// IMAGE GALLERY GA4
		$('figure.image').click(function(event) {
			
			var isGallery = ($(this).find('.enlarge').length > 0 ? true : false);
			 
			if (isGallery) {
				var href = $(location).attr('pathname');
				var title = $('.post-single-title').text().trim();
				//console.log("TITLE: " + title + " - LOCATION: " + href);
				
				window.dataLayer = window.dataLayer || [];
				window.dataLayer.push({
					event: "photo",
					articleURL: href,
					articleTitle: title,
                    photoField: sectionLabel
				});
				console.log("DATA LAYER IMAGE GALLERY ", window.dataLayer);
			}
			
		});
		
		// ABBONATI GA4
		$('.register').click(function(event){
			event.preventDefault();
			var href = $(this).attr('href');
			
		    window.dataLayer = window.dataLayer || [];
		    window.dataLayer.push({
				event: "abbonati",
				category: "CTA",
				action: "abbonati"
			});
			console.log("DATA LAYER ABBONATI ", window.dataLayer);
		    setTimeout(function(){location.href = href}, 1000);
		});
		
		// MARQUEE
		$(document).on('click', '.marquee-content a', function (e) {
		    e.preventDefault();
			var href = this.href;
			
		    //console.log('Hai cliccato:', this.href);
		
		    window.dataLayer = window.dataLayer || [];
		    window.dataLayer.push({
				event: "clickSpeciale",
				articleURL: href,
				specialeTitle: $(this).text().trim(),
				specialePosition: 'Bottom Header'
			});
			console.log("DATA LAYER MARQUEE ", window.dataLayer);
		    setTimeout(function(){location.href = href}, 1000);
		});
		
		// TEASER SPECIALI
		$(document).on(
		    'click',
		    '.teaser-speciali .speciale-title a,        \
		     .teaser-speciali .title a,                 \
		     .teaser-speciali .button',                 
		
		    function (e) {
		      const href      = this.href || $(this).attr('href') || '';   
		      const testo     = $(this).text().trim();                     
		      
		      e.preventDefault();
		      
		      //console.log('CLICK teaser-speciali →', { href, testo });
		      
		      window.dataLayer = window.dataLayer || [];
			  window.dataLayer.push({
					event: "clickSpeciale",
					articleURL: href,
					specialeTitle: testo,
					specialePosition: 'Sidebar'
		      });
			  console.log("DATA LAYER TEASER SPECIALI ", window.dataLayer);
			  setTimeout(function(){location.href = href}, 1000);
		    }
		);
        
		// HOT TOPICS
		$('.topics ul li a').each(function (index) {
	      $(this).on('click', function (e) {
	        var $link = $(this);
	        var topicText = $.trim($link.text());
	        var topicHref = $link.attr('href');
	        var posizione = $link.closest('li').index() + 1;
	
	        // Push nel dataLayer per GA4
	        window.dataLayer = window.dataLayer || [];
	        window.dataLayer.push({
	          event: 'clickHotTopics',
	          hotTopicsLabel: topicText,
	          hotTopicsPosition: posizione
	        });
	
	        e.preventDefault();
	      	console.log("DATA LAYER HOT TOPICS ", window.dataLayer);
		  	setTimeout(function(){location.href = topicHref}, 1000);
	      });
	    });        
		
		// Rimuovo i DIV pubblicitari
		if (typeof noADV !== 'undefined' && noADV) {
			 $('#OMB_1').hide();
			 $('.adv-slot').hide();
		}
		
	});
</script>
 

