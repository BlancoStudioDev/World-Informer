<script type="text/javascript" src="/sito/jsnew/tc-string-parse.min.js"></script>                
<script type="text/javascript">
	if (!withinCMS()) {
		
		var loc = document.location.toString();
		
		if (loc.indexOf('ansabrasil.com.br') !== -1 || loc.indexOf('ansalatina.com') !== -1 || loc.indexOf('/english') !== -1 || loc.indexOf('/china') !== -1 || loc.indexOf('/ansamednew') !== -1 ) {
			console.log("NO CONSENT SOLUTION DEPLOYED!!! " + document.location);
			
			if (typeof noADV === 'undefined' || !noADV) { 
                    var scriptMgid = document.createElement('script');
                    scriptMgid.type = 'text/javascript';
                    scriptMgid.src = '//jsc.mgid.com/site/1066641.js';
                    document.body.appendChild(scriptMgid); 
            }
            
		}
		else {
			// Controllo la presenza del cookie di sottoscrizione
			var isAbbonato = getCookie("sub");
			if (isAbbonato === undefined) {
				// Controllo se l'utente loggato
				if (isLogged()) {
					// Controllo i dati d'accesso e visualizzo il wall o la consent
					checkAccessList();
				}
				else {
					// L'utente non loggato, mostro il cookie wall
					showCookieWall();
				}
			}
			else {
				if (isAbbonato === '0') {
					showCookieWall();
				}
				else {
					showConsentSolution();
				}
			}
		}
	}
</script>




