	//console.log("LOCATION: ", $(location));
	var env = "staging";
	if (($(location).attr("origin").indexOf("ansacmsnew") != -1) || ($(location).attr("origin").indexOf("www.ansa.it") != -1)) {
		env = "prod";
	}
	
	
	
	// SEZIONI
	
  	// HOMEPAGE
