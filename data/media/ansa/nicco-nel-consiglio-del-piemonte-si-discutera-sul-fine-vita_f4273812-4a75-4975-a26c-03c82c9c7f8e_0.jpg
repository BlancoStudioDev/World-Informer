			pageSubcategoryLevel2: sectionLabel
		});*/
	
	
	let dataLayerGlobal = Object.assign({},
		{event: "globalVariables"},
		{environment: env},
		{customerType: customerTypeVar},
		{loggedIn: loggedInVar},
	  	userId === null ? null : {userId: userId},
	  	{subscribed: subscribedVar},
		{pageType: pType},
		{pageSubcategoryLevel2: sectionLabel}
	);
		
